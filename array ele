#include <stdio.h>
int main()
{
    int nums[] = {1, 2, 3, 4, 2};
    int n = 5;
    int found = 0;
   for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            if (nums[i] == nums[j]) {
                found = 1;
                break;
            }
        }
        if (found) break;
    }
        if (found)
        printf("True\n");   // duplicate exists
    else
        printf("False\n");  // all elements are distinct
   return 0;
}
